    def fetch_labelary_preview(self):
        zpl = self.entrada_texto.get("1.0", tk.END).strip()
        if not zpl: return
        
        try:
            dpi = self.combo_dpi.get()
            width = float(self.spin_width.get())
            height = float(self.spin_height.get())
            unit = self.combo_unit.get()
            
            # Convert to inches for API if needed, but Labelary supports dpmm logic via URL
            # Actually easier to use inches for URL: /v1/printers/{dpmm}/labels/{width}x{height}
            # dpmm: 8dpmm (203dpi) or 12dpmm (300dpi) or 24dpmm (600dpi)
            
            dpmm = 8
            if dpi == "300": dpmm = 12
            elif dpi == "600": dpmm = 24
            
            # Convert dimensions to inches for the URL
            if unit == "mm":
                w_in = width / 25.4
                h_in = height / 25.4
            elif unit == "cm":
                w_in = width / 2.54
                h_in = height / 2.54
            else:
                w_in = width
                h_in = height
            
            url = f"http://api.labelary.com/v1/printers/{dpmm}dpmm/labels/{w_in:.2f}x{h_in:.2f}/0/"
            
            response = requests.post(url, files={'file': zpl}, stream=True)
            
            if response.status_code == 200:
                response.raw.decode_content = True
                image = Image.open(response.raw)
                
                # Resize to fit panel if too big? 
                # For now show as returned to reflect real size/quality
                # Maybe scale down if huge for display?
                # Max view size: ~500x800
                
                # Keep original API image
                self._labelary_image_raw = image
                
                # Display
                photo = ImageTk.PhotoImage(image)
                
                # Update UI in main thread
                def update_ui():
                    self.label_labelary_image.config(image=photo, text="")
                    self.label_labelary_image.image = photo # Keep ref
                
                self.root.after(0, update_ui)
                
            else:
                def show_err():
                    self.label_labelary_image.config(image="", text=f"Erro API: {response.status_code}\n{response.text}")
                self.root.after(0, show_err)
                
        except Exception as e:
            def show_ex():
                self.label_labelary_image.config(image="", text=f"Erro: {e}")
            self.root.after(0, show_ex)

    def atualizar_visualizacao(self):
        codigo_zpl = self.entrada_texto.get("1.0", tk.END)

        elementos = []
        # Parse Text - Updated regex to capture font identifier (A0, A, etc.)
        # ^A(font_id),h,w ... or ^A@ ... we focus on ^A(id),h,w
        for match in re.finditer(r'\^FO(\d+),(\d+)\^A([A-Z0-9@]+),(\d+),(\d+)(\^FH)?\^FD([^\^]+)\^FS', codigo_zpl):
            x, y, font_id, altura_fonte, largura_fonte, _, texto = match.groups()
            elementos.append(('texto', int(x), int(y), font_id, int(altura_fonte), int(largura_fonte), texto, match.start(), match.end()))
        
        # Parse Barcode
        for match in re.finditer(r'\^FO(\d+),(\d+)\^BY[^\^]+\^B[^\^]+\^FD([^\^]+)\^FS', codigo_zpl):
            x, y, dados = match.groups()
            elementos.append(('codigo_barras', int(x), int(y), dados, match.start(), match.end()))

        # Parse GFA Images
        # Matches ^FOx,y^GFA,len,len/2,width_bytes,data^FS (with or without comma after GFA)
        for match in re.finditer(r'\^FO(\d+),(\d+)\^GFA,?(\d+),(\d+),(\d+),([A-Fa-f0-9\s]+)\^FS', codigo_zpl):
            x, y, total_bytes, total_bytes_displayed, width_bytes, data = match.groups()
            elementos.append(('imagem_gfa', int(x), int(y), int(width_bytes), data, match.start(), match.end()))

        # Clear canvas items except rectangle (though find_all clears everything if not careful, original code cleared based on type)
        # Original code cleared items with type "text" or "image".
        for item in self.canvas.find_all():
            if self.canvas.type(item) in ("text", "image"):
                self.canvas.delete(item)
        self.canvas.dados_codigo_barras = {}
        self.canvas.dados_texto_bitmap = {}
        self.canvas.dados_zpl_posicao = {}  # NEW: Store (match_start, match_end) for each item

        for elemento in elementos:
            if elemento[0] == 'texto':
                _, x, y, font_id, altura_fonte, largura_fonte, texto, match_start, match_end = elemento
                
                # Check font type
                image_rendered = None
                
                # Treat '0', '0N', '0R', '0B', '0I' etc as Scalable Font 0
                is_scalable = font_id.startswith('0')
                
                if is_scalable:
                    # Scalable font (Arial)
                    image_rendered = render_scalable_text(texto, int(altura_fonte), int(largura_fonte))
                else:
                    # Bitmap font fallback (Pixel font)
                    image_rendered = render_bitmap_text(texto, int(altura_fonte), int(largura_fonte))
                
                if image_rendered:
                     fator_escala = 1 # Already scaled in engine
                     foto = ImageTk.PhotoImage(image_rendered)
                     item = self.canvas.create_image(x + self.deslocamento_x, y + self.deslocamento_y, image=foto, anchor=tk.NW)
                     
                     # Store ZPL position for unique identification
                     self.canvas.dados_zpl_posicao[item] = (match_start, match_end, 'texto')
                     
                     # Tag bind for drag
                     self.canvas.tag_bind(item, "<ButtonPress-1>", self.ao_pressionar_elemento)
                     self.canvas.tag_bind(item, "<B1-Motion>", self.ao_arrastar_elemento)
                     self.canvas.tag_bind(item, "<ButtonRelease-1>", self.ao_soltar_arrasto)
                     
                     # Store metadata on canvas item
                     self.canvas.itemconfig(item, tags=("current", "texto_bitmap"))
                     self.canvas.dados_texto_bitmap[item] = texto
                     
                     # Keep refs
                     if not hasattr(self.canvas, '_imagens'): self.canvas._imagens = {}
                     self.canvas._imagens[item] = foto
                     if not hasattr(self.canvas, '_fotos'): self.canvas._fotos = []
                     self.canvas._fotos.append(foto)

                else:
                    # Fallback to Tkinter Text (should happen rarely now)
                    font_size = -int(altura_fonte)
                    item = self.canvas.create_text(x + self.deslocamento_x, y + self.deslocamento_y, text=texto, anchor=tk.NW,
                                              font=("Arial", font_size, "bold"))
                    # Store ZPL position for unique identification
                    self.canvas.dados_zpl_posicao[item] = (match_start, match_end, 'texto')
                    self.canvas.tag_bind(item, "<ButtonPress-1>", self.ao_pressionar_elemento)
                    self.canvas.tag_bind(item, "<B1-Motion>", self.ao_arrastar_elemento)
                    self.canvas.tag_bind(item, "<ButtonRelease-1>", self.ao_soltar_arrasto)
            elif elemento[0] == 'codigo_barras':
                _, x, y, dados, match_start, match_end = elemento
                escritor = ImageWriter()
                escritor.dpi = 300
                escritor.altura_modulo = 5.0
                try:
                    upca = barcode.get('upca', dados, writer=escritor)
                    imagem = upca.render()
                    foto = ImageTk.PhotoImage(imagem)
                    item = self.canvas.create_image(x + self.deslocamento_x, y + self.deslocamento_y, image=foto, anchor=tk.NW)
                    
                    self.canvas.dados_codigo_barras[item] = dados
                    # Store ZPL position for unique identification
                    self.canvas.dados_zpl_posicao[item] = (match_start, match_end, 'codigo_barras')
                    tamanho = self.tamanhos_codigo_barras.get(item, 1)
                    imagem = redimensionar_imagem_codigo_barras(imagem, float(tamanho))
                    foto = ImageTk.PhotoImage(imagem) # Update photo ref
                    self.canvas.itemconfig(item, image=foto)
                    
                    self.canvas.tag_bind(item, "<ButtonPress-1>", self.ao_pressionar_elemento)
                    self.canvas.tag_bind(item, "<B1-Motion>", self.ao_arrastar_elemento)
                    self.canvas.tag_bind(item, "<ButtonRelease-1>", self.ao_soltar_arrasto)

                    # Keep references
                    if not hasattr(self.canvas, '_imagens'):
                        self.canvas._imagens = {}
                    self.canvas._imagens[item] = foto
                    
                    if not hasattr(self.canvas, '_fotos'):
                        self.canvas._fotos = []
                    self.canvas._fotos.append(foto)
                except Exception as e:
                    print(f"Erro ao gerar codigo de barras: {e}")
            elif elemento[0] == 'imagem_gfa':
                _, x, y, width_bytes, data, match_start, match_end = elemento
                try:
                    imagem = zpl_gfa_to_image(data, width_bytes)
                    if imagem:
                         # Invert colors? ZPL 1=black, PIL 1=white often.
                         # Let's try to invert if it looks inverted.
                         # Usually standard PIL '1' loaded from bytes: 0=black, 1=white.
                         # ZPL: 1=black. So we might need to invert bits.
                         # But ImageOps.invert/PIL logic is tricky with 1-bit.
                         # Let's display as is first. User can report if inverted.
                         
                         foto = ImageTk.PhotoImage(imagem)
                         item = self.canvas.create_image(x + self.deslocamento_x, y + self.deslocamento_y, image=foto, anchor=tk.NW)
                         
                         # Store ZPL position for unique identification
                         self.canvas.dados_zpl_posicao[item] = (match_start, match_end, 'imagem_gfa')
                         
                         # Use uniform drag handler for images too (replaces arrastar_imagem_direto)
                         self.canvas.tag_bind(item, "<ButtonPress-1>", self.ao_pressionar_elemento)
                         self.canvas.tag_bind(item, "<B1-Motion>", self.ao_arrastar_elemento)
                         self.canvas.tag_bind(item, "<ButtonRelease-1>", self.ao_soltar_arrasto)

                         if not hasattr(self.canvas, '_imagens'): self.canvas._imagens = {}
                         self.canvas._imagens[item] = foto
                         
                         if not hasattr(self.canvas, '_fotos'): self.canvas._fotos = []
                         self.canvas._fotos.append(foto)
                except Exception as e:
                    print(f"Erro ao renderizar GFA: {e}")

    def ao_pressionar_elemento(self, evento):
        self.canvas_element_current = self.canvas.find_withtag("current")
        self.canvas_x_current = evento.x
        self.canvas_y_current = evento.y
        
        # Calculate offset from mouse to element top-left corner
        if self.canvas_element_current:
            coords = self.canvas.coords(self.canvas_element_current)
            if coords:
                self.arrasto_offset_x = evento.x - coords[0]
                self.arrasto_offset_y = evento.y - coords[1]
            else:
                self.arrasto_offset_x = 0
                self.arrasto_offset_y = 0
        
        # Initialize drag border rectangle
        self.retangulo_arrasto = None

    def ao_arrastar_elemento(self, evento):
        if not self.canvas_element_current:
            return
        
        # Hide resize handles during drag for cleaner visual
        if self.handles_redimensionar:
            self.ocultar_handles()
            
        rx1, ry1, rx2, ry2 = self.canvas.coords(self.retangulo)
        valor_snap = int(self.snap.get())
        
        # Current element coords
        coords = self.canvas.coords(self.canvas_element_current)
        if not coords: return
        x1, y1 = coords[:2]
        
        # Calculate new position maintaining grab offset
        offset_x = getattr(self, 'arrasto_offset_x', 0)
        offset_y = getattr(self, 'arrasto_offset_y', 0)
        
        x2 = evento.x - offset_x
        y2 = evento.y - offset_y
        
        # Apply snap
        x2 = round((x2 + 1) / valor_snap) * valor_snap
        y2 = round((y2 + 1) / valor_snap) * valor_snap
        
        if self.trava_eixo_x.get():
            x2 = x1
        if self.trava_eixo_y.get():
            y2 = y1

        bbox = self.canvas.bbox(self.canvas_element_current)
        largura_elemento = 0
        altura_elemento = 0
        if bbox:
            largura_elemento = bbox[2] - bbox[0]
            altura_elemento = bbox[3] - bbox[1]

        if x2 < rx1: x2 = rx1
        if y2 < ry1: y2 = ry1
        if x2 + largura_elemento > rx2: x2 = rx2 - largura_elemento
        if y2 + altura_elemento > ry2: y2 = ry2 - altura_elemento

        # Move element
        self.canvas.coords(self.canvas_element_current, x2, y2)
        
        # Update or create drag border rectangle
        if hasattr(self, 'retangulo_arrasto') and self.retangulo_arrasto:
            self.canvas.coords(self.retangulo_arrasto, x2, y2, x2 + largura_elemento, y2 + altura_elemento)
        else:
            self.retangulo_arrasto = self.canvas.create_rectangle(
                x2, y2, x2 + largura_elemento, y2 + altura_elemento,
                outline="black", width=1, dash=(2, 2), tags="arrasto_border"
            )

        x_relativo = x2 - rx1
        y_relativo = y2 - ry1
        self.rotulo_coordenadas.config(text=f"x: {x_relativo + 10}, y: {y_relativo + 10}")

        self.rotulo_coordenadas.config(text=f"x: {x_relativo + 10}, y: {y_relativo + 10}")

        if self.canvas_element_current[0] not in self.elementos_movidos:
             self.elementos_movidos.append(self.canvas_element_current[0])
    
    def ao_soltar_arrasto(self, evento):
        """Clean up drag border and update ZPL automatically."""
        if hasattr(self, 'retangulo_arrasto') and self.retangulo_arrasto:
            self.canvas.delete(self.retangulo_arrasto)
            self.retangulo_arrasto = None
            
        # Update ZPL position automatically on release
        if self.elementos_movidos:
            self.aplicar_mudancas()
            self.atualizar_visualizacao()  # Refresh canvas and indices

    def aplicar_mudancas(self):
        codigo_zpl = self.entrada_texto.get("1.0", tk.END)
        
        # Collect all updates with their positions
        # Format: [(match_start, match_end, new_coords_str, element_type), ...]
        updates = []
        
        for item in self.elementos_movidos:
            if item not in self.canvas.dados_zpl_posicao:
                continue
                
            match_start, match_end, element_type = self.canvas.dados_zpl_posicao[item]
            x, y = self.canvas.coords(item)
            novo_x = max(0, int(x) - self.deslocamento_x)
            novo_y = max(0, int(y) - self.deslocamento_y)
            
            # Get the original ZPL snippet for this element
            original_snippet = codigo_zpl[match_start:match_end]
            
            # Replace only the ^FO coordinates in this specific snippet
            new_snippet = re.sub(r'\^FO\d+,\d+', f'^FO{novo_x},{novo_y}', original_snippet, count=1)
            
            updates.append((match_start, match_end, new_snippet))
        
        # Sort by position descending to avoid offset issues when replacing
        updates.sort(key=lambda x: x[0], reverse=True)
        
        # Apply updates from end to start
        for match_start, match_end, new_snippet in updates:
            codigo_zpl = codigo_zpl[:match_start] + new_snippet + codigo_zpl[match_end:]

        self.entrada_texto.delete("1.0", tk.END)
        self.entrada_texto.insert(tk.END, codigo_zpl)

        self.elementos_movidos = []

    def arrastar_imagem_direto(self, evento):
        # Specific handler for imported images (direct ZPL update)
        if self.canvas.type(self.canvas_element_current) == "image":
             # Same logic as VPL.py lines 408-453
             x, y = self.canvas.coords(self.canvas_element_current)
             x += evento.x - self.canvas_x_current
             y += evento.y - self.canvas_y_current
             
             if self.trava_eixo_x.get(): x = self.canvas.coords(self.canvas_element_current)[0]
             if self.trava_eixo_y.get(): y = self.canvas.coords(self.canvas_element_current)[1]

             rx1, ry1, rx2, ry2 = self.canvas.coords(self.retangulo)
             bbox = self.canvas.bbox(self.canvas_element_current)
             w = bbox[2] - bbox[0]
             h = bbox[3] - bbox[1]

             if x < rx1: x = rx1
             if y < ry1: y = ry1
             if x + w > rx2: x = rx2 - w
             if y + h > ry2: y = ry2 - h

             self.canvas.coords(self.canvas_element_current, x, y)
             self.canvas_x_current = evento.x
             self.canvas_y_current = evento.y

             # Update ZPL directly
             codigo_zpl = self.entrada_texto.get("1.0", tk.END)
             # Regex for GFA (image)
             novo_codigo_zpl = re.sub(r'(\^FO)\d+,\d+(\^GFA[^\^]+\^FS)', rf'\g<1>{int(x)},{int(y)}\g<2>', codigo_zpl)
             self.entrada_texto.delete("1.0", tk.END)
             self.entrada_texto.insert(tk.END, novo_codigo_zpl)

