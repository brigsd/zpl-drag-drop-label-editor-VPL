        # Reset all button appearances
        self.botao_texto.config(relief=tk.RAISED)
        self.botao_imagem.config(relief=tk.RAISED)
        self.botao_codigo_barras.config(relief=tk.RAISED)
        self.botao_selecao.config(relief=tk.RAISED)
        
